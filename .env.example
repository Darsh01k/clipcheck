# ClipCheck Configuration
# Copy this file to backend/.env and fill in your values

# Primary: OpenRouter (get key at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Fallback providers (used when OpenRouter is rate-limited)
# Groq: https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-key-here
# NVIDIA: https://build.nvidia.com/ (API Catalog)
NVIDIA_API_KEY=nvapi-your-nvidia-key-here

# Optional: change the AI model (must be a free model on OpenRouter)
# Options: meta-llama/llama-3.3-70b-instruct:free, google/gemma-4-31b-it:free,
#          qwen/qwen3-coder:free, nousresearch/hermes-3-llama-3.1-405b:free
AI_MODEL=meta-llama/llama-3.3-70b-instruct:free

PORT=8000

# YouTube Data API key (optional, used for metadata extraction when transcript is unavailable)
# Get one at https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your-youtube-api-key-here
